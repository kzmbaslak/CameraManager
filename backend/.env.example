# Kamera şifrelerini şifrelemek için AES-256 key (base64, 32 bayt)
# Üretmek için: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
CAMERA_ENCRYPTION_KEY=BURAYA_32_BAYTLIK_BASE64_ANAHTAR_YAZ

# JWT imzalama için gizli anahtar
# Üretmek için: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=BURAYA_UZUN_RASTGELE_ANAHTAR_YAZ

# JWT token geçerlilik süresi (dakika)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# İlk kurulumda DB'de kullanıcı yoksa admin oluşturmak için doldurun.
# Boş bırakılırsa otomatik varsayılan admin oluşturulmaz.
INITIAL_ADMIN_USERNAME=
INITIAL_ADMIN_PASSWORD=

# Frontend geliştirme originleri; production aynı origin kullandığında CORS gerekmez.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
